Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

%labels
    Author David Collins {david.collins@ucsf.edu} with assistance from UCSF Enterprise ChatGPT
    Description DeepLabCut 3.x offline HPC image with writable runtime cache fallback

%environment
    # Runtime cache policy:
    #   1) Use $DLC_CACHE_ROOT if the caller sets it
    #   2) Otherwise prefer $HOME/.cache/deeplabcut when HOME is writable
    #   3) Otherwise use $TMPDIR/dlc-cache or /tmp/dlc-cache
    #
    # The bootstrap helper also copies the baked cache from /opt/dlc-cache-ro
    # into the writable runtime cache the first time it is used.
    . /opt/dlc-bin/dlc-cache-bootstrap.sh
    dlc_cache_bootstrap

%post
    set -eu

    export DEBIAN_FRONTEND=noninteractive

    apt-get update
    apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        ffmpeg \
        git \
        libglib2.0-0 \
        libgl1 \
        libsm6 \
        libxext6 \
        libxrender1 \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        && rm -rf /var/lib/apt/lists/*

    mkdir -p \
        /opt/dlc-bin \
        /opt/dlc-cache-ro/torch/hub/checkpoints \
        /opt/dlc-cache-ro/huggingface/hub \
        /opt/dlc-cache-ro/huggingface/transformers \
        /opt/dlc-prime \
        /opt/dlc-home

    cat > /opt/dlc-bin/dlc-cache-bootstrap.sh <<'SH'
#!/bin/sh
set -eu

dlc_cache_bootstrap() {
    # Caller override wins.
    if [ -n "${DLC_CACHE_ROOT:-}" ]; then
        :
    elif [ -n "${HOME:-}" ] && [ -w "${HOME:-}" ]; then
        DLC_CACHE_ROOT="${HOME}/.cache/deeplabcut"
    elif [ -n "${TMPDIR:-}" ] && [ -w "${TMPDIR:-}" ]; then
        DLC_CACHE_ROOT="${TMPDIR}/dlc-cache"
    else
        DLC_CACHE_ROOT="/tmp/dlc-cache"
    fi

    export DLC_CACHE_ROOT
    export XDG_CACHE_HOME="${DLC_CACHE_ROOT}"
    export TORCH_HOME="${DLC_CACHE_ROOT}/torch"
    export HF_HOME="${DLC_CACHE_ROOT}/huggingface"
    export HF_HUB_CACHE="${HF_HOME}/hub"
    export TRANSFORMERS_CACHE="${HF_HOME}/transformers"
    export MPLBACKEND="${MPLBACKEND:-Agg}"
    export PYTHONUNBUFFERED="${PYTHONUNBUFFERED:-1}"

    mkdir -p \
        "${TORCH_HOME}/hub/checkpoints" \
        "${HF_HUB_CACHE}" \
        "${HF_HOME}/transformers"

    # Seed the writable runtime cache once from the baked read-only cache.
    # This is a best-effort copy; failures fall back to an empty writable cache.
    baked_root="/opt/dlc-cache-ro"
    marker="${DLC_CACHE_ROOT}/.seeded_from_image"
    if [ -d "${baked_root}" ] && [ ! -f "${marker}" ] && [ "${DLC_CACHE_ROOT}" != "${baked_root}" ]; then
        mkdir -p "${DLC_CACHE_ROOT}"
        cp -a "${baked_root}/." "${DLC_CACHE_ROOT}/" 2>/dev/null || true
        : > "${marker}" 2>/dev/null || true
    fi
}

# Allow sourcing.
return 0 2>/dev/null || exit 0
SH
    chmod 755 /opt/dlc-bin/dlc-cache-bootstrap.sh

    python3 -m pip install --upgrade pip setuptools wheel

    # Use the current DLC prerelease line. Change this one line when upgrading.
    # The PyTorch index below uses the CUDA 12.4 wheel family, matching the CUDA runtime base.
    python3 -m pip install \
        --index-url https://download.pytorch.org/whl/cu124 \
        torch torchvision

    python3 -m pip install --pre \
        "deeplabcut[gui,modelzoo,wandb]==3.0.0rc14" \
        pandas pyyaml pillow h5py scipy scikit-image matplotlib seaborn opencv-python-headless

    cat > /opt/dlc-prime/prime_deeplabcut_cache.py <<'PY'
from __future__ import annotations

import os
import subprocess
from pathlib import Path

from PIL import Image

# Build-time priming should target the baked read-only cache tree.
os.environ["DLC_CACHE_ROOT"] = "/opt/dlc-cache-ro"
os.environ["XDG_CACHE_HOME"] = "/opt/dlc-cache-ro"
os.environ["TORCH_HOME"] = "/opt/dlc-cache-ro/torch"
os.environ["HF_HOME"] = "/opt/dlc-cache-ro/huggingface"
os.environ["HF_HUB_CACHE"] = "/opt/dlc-cache-ro/huggingface/hub"
os.environ["TRANSFORMERS_CACHE"] = "/opt/dlc-cache-ro/huggingface/transformers"
os.environ["MPLBACKEND"] = "Agg"
os.environ["PYTHONUNBUFFERED"] = "1"

import torch
import torchvision
import deeplabcut

WORK = Path("/opt/dlc-prime")
VIDEO = WORK / "dummy.mp4"
FRAME = WORK / "dummy_frame.png"
WORK.mkdir(parents=True, exist_ok=True)

# These are the currently available models/detectors for PyTorch engine as of 2026-04-15. May need to be updated over time.
REQUESTED_MODELS = [
    "animaltokenpose_base",
    "cspnext_m",
    "cspnext_s",
    "cspnext_x",
    "ctd_coam_w32",
    "ctd_coam_w48",
    "ctd_prenet_hrnet_w32",
    "ctd_prenet_hrnet_w48",
    "ctd_prenet_rtmpose_m",
    "ctd_prenet_rtmpose_s",
    "ctd_prenet_rtmpose_x",
    "ctd_prenet_rtmpose_x_human",
    "dekr_w18",
    "dekr_w32",
    "dekr_w48",
    "dlcrnet_stride16_ms5",
    "dlcrnet_stride32_ms5",
    "hrnet_w18",
    "hrnet_w32",
    "hrnet_w48",
    "resnet_101",
    "resnet_50",
    "rtmpose_m",
    "rtmpose_s",
    "rtmpose_x",
    "top_down_cspnext_m",
    "top_down_cspnext_s",
    "top_down_cspnext_x",
    "top_down_hrnet_w18",
    "top_down_hrnet_w32",
    "top_down_hrnet_w48",
    "top_down_resnet_101",
    "top_down_resnet_50",
]

REQUESTED_DETECTORS = [
    "ssdlite",
    "fasterrcnn_mobilenet_v3_large_fpn",
    "fasterrcnn_resnet50_fpn_v2",
]

TIMM_BACKBONES = [
    "hrnet_w18",
    "hrnet_w32",
    "hrnet_w48",
    "cspnext_s",
    "cspnext_m",
    "cspnext_x",
    "rtmpose_s",
    "rtmpose_m",
    "rtmpose_x",
]

MODEL_HINTS = {
    "animaltokenpose_base": ["animaltokenpose_base"],
    "cspnext_m": ["cspnext_m"],
    "cspnext_s": ["cspnext_s"],
    "cspnext_x": ["cspnext_x"],
    "ctd_coam_w32": ["cspnext_s", "cspnext_m"],
    "ctd_coam_w48": ["cspnext_x"],
    "ctd_prenet_hrnet_w32": ["hrnet_w32"],
    "ctd_prenet_hrnet_w48": ["hrnet_w48"],
    "ctd_prenet_rtmpose_m": ["rtmpose_m"],
    "ctd_prenet_rtmpose_s": ["rtmpose_s"],
    "ctd_prenet_rtmpose_x": ["rtmpose_x"],
    "ctd_prenet_rtmpose_x_human": ["rtmpose_x"],
    "dekr_w18": ["hrnet_w18"],
    "dekr_w32": ["hrnet_w32"],
    "dekr_w48": ["hrnet_w48"],
    "dlcrnet_stride16_ms5": ["resnet_50"],
    "dlcrnet_stride32_ms5": ["resnet_101"],
    "hrnet_w18": ["hrnet_w18"],
    "hrnet_w32": ["hrnet_w32"],
    "hrnet_w48": ["hrnet_w48"],
    "resnet_101": ["resnet_101"],
    "resnet_50": ["resnet_50"],
    "rtmpose_m": ["rtmpose_m"],
    "rtmpose_s": ["rtmpose_s"],
    "rtmpose_x": ["rtmpose_x"],
    "top_down_cspnext_m": ["cspnext_m"],
    "top_down_cspnext_s": ["cspnext_s"],
    "top_down_cspnext_x": ["cspnext_x"],
    "top_down_hrnet_w18": ["hrnet_w18"],
    "top_down_hrnet_w32": ["hrnet_w32"],
    "top_down_hrnet_w48": ["hrnet_w48"],
    "top_down_resnet_101": ["resnet_101"],
    "top_down_resnet_50": ["resnet_50"],
}


def run(cmd: list[str]) -> None:
    subprocess.run(cmd, check=True)


def log(msg: str) -> None:
    print(f"[prime] {msg}", flush=True)


def skip(msg: str, exc: Exception) -> None:
    print(f"[skip ] {msg}: {exc}", flush=True)


def make_dummy_media() -> None:
    run([
        "ffmpeg", "-y",
        "-f", "lavfi", "-i", "color=c=black:s=128x128:d=1",
        "-pix_fmt", "yuv420p",
        str(VIDEO),
    ])
    Image.new("RGB", (128, 128), (0, 0, 0)).save(FRAME)


def prime_torchvision_weights() -> None:
    from torchvision.models import (
        MobileNet_V3_Large_Weights,
        ResNet101_Weights,
        ResNet50_Weights,
    )
    from torchvision.models.detection import (
        FasterRCNN_MobileNet_V3_Large_FPN_Weights,
        FasterRCNN_ResNet50_FPN_V2_Weights,
        SSDLite320_MobileNet_V3_Large_Weights,
        fasterrcnn_mobilenet_v3_large_fpn,
        fasterrcnn_resnet50_fpn_v2,
        ssdlite320_mobilenet_v3_large,
    )

    log("priming torchvision classification checkpoints")
    torchvision.models.resnet50(weights=ResNet50_Weights.DEFAULT)
    torchvision.models.resnet101(weights=ResNet101_Weights.DEFAULT)
    torchvision.models.mobilenet_v3_large(weights=MobileNet_V3_Large_Weights.DEFAULT)

    log("priming torchvision detector checkpoints")
    fasterrcnn_resnet50_fpn_v2(
        weights=FasterRCNN_ResNet50_FPN_V2_Weights.DEFAULT,
        weights_backbone=None,
    )
    fasterrcnn_mobilenet_v3_large_fpn(
        weights=FasterRCNN_MobileNet_V3_Large_FPN_Weights.DEFAULT,
        weights_backbone=None,
    )
    ssdlite320_mobilenet_v3_large(
        weights=SSDLite320_MobileNet_V3_Large_Weights.DEFAULT,
        weights_backbone=None,
    )


def prime_timm_backbones() -> None:
    try:
        import timm
    except Exception as exc:
        skip("import timm", exc)
        return

    for name in TIMM_BACKBONES:
        label = f"timm.create_model({name})"
        try:
            log(label)
            timm.create_model(name, pretrained=True)
        except Exception as exc:
            skip(label, exc)


def prime_superanimal_inference() -> None:
    # Best-effort coverage of the model zoo families documented in DLC 3.x.
    families = [
        ("superanimal_quadruped", ["hrnet_w32", "dlcrnet"], ["fasterrcnn_resnet50_fpn_v2", "fasterrcnn_mobilenet_v3_large_fpn", "ssdlite"]),
        ("superanimal_topviewmouse", ["hrnet_w32", "dlcrnet"], ["fasterrcnn_resnet50_fpn_v2", "fasterrcnn_mobilenet_v3_large_fpn", "ssdlite"]),
        ("superanimal_humanbody", ["rtmpose_x"], ["fasterrcnn_resnet50_fpn_v2", "fasterrcnn_mobilenet_v3_large_fpn", "ssdlite"]),
    ]

    for superanimal_name, model_names, detector_names in families:
        for model_name in model_names:
            detector_iter = [None] if model_name == "dlcrnet" else detector_names
            for detector_name in detector_iter:
                kwargs = {
                    "videos": [str(VIDEO)],
                    "superanimal_name": superanimal_name,
                    "model_name": model_name,
                    "video_adapt": False,
                    "dest_folder": str(WORK),
                }
                if detector_name is not None:
                    kwargs["detector_name"] = detector_name
                label = f"video_inference_superanimal({superanimal_name}, {model_name}, {detector_name})"
                try:
                    log(label)
                    deeplabcut.video_inference_superanimal(**kwargs)
                except Exception as exc:
                    skip(label, exc)


def create_dummy_project() -> str:
    # Use an actual DLC project so transfer-learning / training code paths have
    # a realistic config file to inspect during priming.
    try:
        project = deeplabcut.create_new_project(
            project="offline-prime",
            experimenter="apptainer",
            videos=[str(VIDEO)],
            copy_videos=True,
            multianimal=True,
            working_directory=str(WORK),
        )
        return str(Path(project) / "config.yaml")
    except Exception as exc:
        skip("create_new_project", exc)
        return str(WORK / "dummy-project" / "config.yaml")


def prime_registry_and_requested_models(dummy_cfg: str) -> None:
    try:
        from deeplabcut.pose_estimation_pytorch import available_detectors, available_models
        models = list(available_models())
        detectors = list(available_detectors())
        log(f"available models: {models}")
        log(f"available detectors: {detectors}")
    except Exception as exc:
        skip("available_models/available_detectors", exc)
        models = []
        detectors = []

    # Ensure the user-requested models are always included, even if registry
    # names shift slightly across DLC releases.
    model_set = sorted(set(models) | set(REQUESTED_MODELS))
    detector_set = sorted(set(detectors) | set(REQUESTED_DETECTORS))

    try:
        from deeplabcut.modelzoo import build_weight_init
    except Exception as exc:
        skip("import build_weight_init", exc)
        return

    for model in model_set:
        hints = MODEL_HINTS.get(model, [])
        if model == "animaltokenpose_base":
            # Inference-only model in current DLC docs; keep best-effort attempt.
            pass

        # First try any directly associated pretrained backbone names.
        for hint in hints:
            if hint in TIMM_BACKBONES:
                try:
                    import timm
                    log(f"timm.create_model({hint}) [via {model}]")
                    timm.create_model(hint, pretrained=True)
                except Exception as exc:
                    skip(f"timm.create_model({hint}) via {model}", exc)

        # Then exercise the DLC registry path. This is intentionally
        # best-effort; some entries are aliases or may require a specific
        # detector/backbone pairing.
        use_detectors = detector_set if (model.startswith("top_down_") or model.startswith("ctd_") or model.startswith("rtmpose_") or model.startswith("ctd_prenet_") or model.startswith("ctd_coam_")) else [None]

        for detector in use_detectors:
            label = f"build_weight_init({model}, {detector})"
            try:
                kwargs = {
                    "cfg": dummy_cfg,
                    "super_animal": "superanimal_quadruped",
                    "model_name": model,
                    "with_decoder": False,
                }
                if detector is not None:
                    kwargs["detector_name"] = detector
                log(label)
                build_weight_init(**kwargs)
            except Exception as exc:
                skip(label, exc)


def main() -> None:
    print("DeepLabCut:", getattr(deeplabcut, "__version__", "unknown"), flush=True)
    make_dummy_media()
    dummy_cfg = create_dummy_project()
    prime_torchvision_weights()
    prime_timm_backbones()
    prime_superanimal_inference()
    prime_registry_and_requested_models(dummy_cfg)
    print("Priming complete.", flush=True)


if __name__ == "__main__":
    main()
PY

    python3 /opt/dlc-prime/prime_deeplabcut_cache.py

    # Make the baked cache read-only so the image remains self-contained.
    chmod -R a-w /opt/dlc-cache-ro /opt/dlc-bin /opt/dlc-prime /opt/dlc-home || true

%test
    set -eu
    . /opt/dlc-bin/dlc-cache-bootstrap.sh
    dlc_cache_bootstrap
    python3 - <<'PY'
from __future__ import annotations

import os
from pathlib import Path

import torch
from torchvision.models.detection import (
    FasterRCNN_MobileNet_V3_Large_FPN_Weights,
    fasterrcnn_mobilenet_v3_large_fpn,
)

print("DLC_CACHE_ROOT=", os.environ["DLC_CACHE_ROOT"])
print("TORCH_HOME=", torch.hub.get_dir())
Path(os.environ["TORCH_HOME"]).mkdir(parents=True, exist_ok=True)
(Path(os.environ["TORCH_HOME"]) / "write_test").write_text("ok", encoding="utf-8")
# This should succeed without any network access if the cache bootstrap worked.
fasterrcnn_mobilenet_v3_large_fpn(
    weights=FasterRCNN_MobileNet_V3_Large_FPN_Weights.DEFAULT,
    weights_backbone=None,
)
print("smoke_test_ok")
PY

%runscript
    . /opt/dlc-bin/dlc-cache-bootstrap.sh
    dlc_cache_bootstrap
    exec python3 "$@"
